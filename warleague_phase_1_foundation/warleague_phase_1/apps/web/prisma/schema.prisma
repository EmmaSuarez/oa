generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  ADMIN
}

enum MembershipTier {
  RECRUIT
  VETERAN
  COMMANDER
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  CANCELED
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  displayName     String
  emailVerifiedAt DateTime?
  role            Role     @default(PLAYER)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  player          Player?
  memberships     Membership[]
}

model Player {
  id           String   @id @default(cuid())
  userId       String   @unique
  glickoRating Float    @default(1500)
  glickoRd     Float    @default(350)
  glickoVol    Float    @default(0.06)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
  leaguePoints LeaguePoint[]
}

model Membership {
  id           String           @id @default(cuid())
  userId       String
  tier         MembershipTier
  status       MembershipStatus @default(ACTIVE)
  billingMonth String
  createdAt    DateTime         @default(now())

  user         User             @relation(fields: [userId], references: [id])

  @@unique([userId, billingMonth])
}

model League {
  id           String   @id @default(cuid())
  year         Int
  seasonNumber Int
  name         String
  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime @default(now())

  tournaments  Tournament[]
  leaguePoints LeaguePoint[]

  @@unique([year, seasonNumber])
}

model Tournament {
  id           String   @id @default(cuid())
  leagueId      String
  name          String
  startsAt      DateTime
  roundCount    Int
  createdAt     DateTime @default(now())

  league        League   @relation(fields: [leagueId], references: [id])
}

model LeaguePoint {
  id        String @id @default(cuid())
  leagueId  String
  playerId  String
  points    Int    @default(0)

  league    League @relation(fields: [leagueId], references: [id])
  player    Player @relation(fields: [playerId], references: [id])

  @@unique([leagueId, playerId])
}
