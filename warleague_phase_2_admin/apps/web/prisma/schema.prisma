
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  role         String   @default("PLAYER")
  createdAt    DateTime @default(now())
  player       Player?
}

model Player {
  id           String @id @default(cuid())
  userId       String @unique
  glickoRating Float  @default(1500)
  user         User   @relation(fields: [userId], references: [id])
}

model League {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
}

model Tournament {
  id        String   @id @default(cuid())
  name      String
  leagueId  String
  createdAt DateTime @default(now())
}

model Match {
  id           String @id @default(cuid())
  tournamentId String
  player1Id    String
  player2Id    String?
  vp1          Int
  vp2          Int
  uniqueKey    String @unique
}
